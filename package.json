{
  "name": "history-here",
  "version": "1.0.3",
  "description": "Browser extension that answers: 🧐 Have I seen this page already?",
  "main": "popup.js",
  "dependencies": {
    "@emotion/css": "11.13.5",
    "date-fns": "4.4.0",
    "hyperapp": "2.0.22",
    "hyperapp-jsx-pragma": "1.3.0",
    "timeago.js": "4.0.2"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/plugin-transform-react-jsx": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "babel-loader": "10.1.1",
    "chrome-webstore-upload-cli": "1.2.0",
    "copy-webpack-plugin": "14.0.0",
    "dot-json": "1.1.0",
    "eslint": "6.1.0",
    "eslint-config-airbnb-base": "14.0.0",
    "eslint-plugin-import": "2.18.2",
    "eslint-plugin-react": "7.14.3",
    "npm-run-all": "4.1.5",
    "vitest": "^4.1.10",
    "webext": "1.9.1-with-submit.1",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1"
  },
  "scripts": {
    "build": "webpack",
    "watch": "webpack --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "cd extension && webstore upload --auto-publish",
    "update-version": "dot-json extension/manifest.json version $(date -u +%y.%-m.%-d.%-H%M)",
    "format": "prettier --trailing-comma --write 'src/**/*.js'"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.4",
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "chrome": "110"
          }
        }
      ]
    ],
    "plugins": [
      [
        "@babel/plugin-transform-react-jsx",
        {
          "runtime": "classic",
          "pragma": "h"
        }
      ]
    ]
  }
}
